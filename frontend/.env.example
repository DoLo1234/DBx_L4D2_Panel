# 后端接口地址
VITE_API_BASE_URL=http://localhost:${VITE_PORT}
# steamcmd下载地址-windows
STEAMCMD_DOWNLOAD_URL_WINDOWS=https://steamcdn-a.akamaihd.net/client/installer/steamcmd.zip
# steamcmd下载地址-linux
STEAMCMD_DOWNLOAD_URL_LINUX=https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz
# 面板登录凭据
PANEL_USER=admin
PANEL_PASSWORD=your_password_here

# JWT密钥
JWT_SECRET=your_jwt_secret_key_change_this

# 服务器路径
SERVER_PATH=/path/to/l4d2server

# SteamCMD路径
STEAMCMD_PATH=/path/to/steamcmd

# 端口
VITE_PORT=11214
